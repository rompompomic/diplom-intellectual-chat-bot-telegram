TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ALLOWED_USER_IDS=123456789

OPENAI_API_KEY=your_openai_api_key
OPENAI_MODEL_PRIMARY=gpt-5-mini
OPENAI_MODEL_SECONDARY=gpt-5.4-mini
OPENAI_MODEL_FALLBACK=gpt-4.1-mini

INTERFACE_LANGUAGE=ru
FILE_SIZE_LIMIT_MB=25
MAX_FILES_PER_OPERATION=100
POWERSHELL_TIMEOUT_SEC=20
LOG_LEVEL=INFO

ALLOWED_DIRS=%USERPROFILE%\\Documents;%USERPROFILE%\\Downloads;%USERPROFILE%\\Desktop;.
ALLOWED_APPS=notepad=C:\\Windows\\System32\\notepad.exe;vscode=C:\\Users\\%USERNAME%\\AppData\\Local\\Programs\\Microsoft VS Code\\Code.exe

ENABLE_STARTUP_BY_DEFAULT=false
SEARCH_DB_PATH=./storage/search_index.db
TEMP_DIR=./temp
LOGS_DIR=./logs
STT_MODEL_SIZE=small
